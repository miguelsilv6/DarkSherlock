# ---------------------------------------------------------------------------
# LLM
# ---------------------------------------------------------------------------
# A app funciona SEM configuração: usa um modelo leve embutido (llama.cpp),
# descarregado automaticamente na 1ª utilização. As variáveis abaixo são
# todas opcionais.

# Modelo embutido por omissão (chave do registry em local_models.py).
# Vazio → "Qwen2.5-0.5B (embutido, ultraleve)". Outras opções:
#   "Qwen2.5-1.5B (embutido, leve)"  |  "Llama-3.2-1B (embutido, leve)"
DARKSHERLOCK_DEFAULT_MODEL=

# Pasta de cache dos GGUF embutidos (default: ./models).
DARKSHERLOCK_MODELS_DIR=

# Ollama (opcional) — se tiveres um servidor Ollama a correr, os seus
# modelos aparecem também na lista de selecção.
OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# DarkForums (clearnet forum MyBB, requer conta) — apenas para investigação
# OSINT/threat-intel. A conta deve ser criada manualmente pelo investigador;
# deixar vazio para manter o engine desactivado.
# ---------------------------------------------------------------------------
DARKFORUMS_USERNAME=
DARKFORUMS_PASSWORD=
DARKFORUMS_BASE_URL=https://darkforums.st
